# PingOne Configuration
PINGONE_CLIENT_ID=your_client_id_here
PINGONE_CLIENT_SECRET=your_client_secret_here
PINGONE_ENVIRONMENT_ID=your_environment_id_here
PINGONE_REGION=NorthAmerica
PINGONE_REDIRECT_URI=http://localhost:3001/auth/callback

# Node Environment
NODE_ENV=development
DEBUG=sso-platform:*

# CORS Settings
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Session
SESSION_SECRET=your_session_secret_change_in_production

# Database (Optional)
DATABASE_URL=
